# ─────────────────────────────────────────────────────────────────
# Amazon Rekognition Delivery Monitor — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── AWS Credentials ─────────────────────────────────────────────
# Option 1: Explicit keys (local dev)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# Option 2: Use IAM Role (Lambda / EC2 — leave blank above)

# ── Camera Source ───────────────────────────────────────────────
# Webcam: 0
# IP Camera: rtsp://username:password@192.168.1.100:554/stream
# Static test image: test_images/delivery_sample.jpg
CAMERA_SOURCE=0

# ── Notifications ────────────────────────────────────────────────
# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Generic HTTP Webhook (e.g., IFTTT, Zapier)
WEBHOOK_URL=https://your-webhook-endpoint.com/delivery

# Email via SMTP (e.g., Gmail App Password)
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENTS=you@email.com,partner@email.com

# ── Config Override ──────────────────────────────────────────────
# Optional: path to a custom config.yaml
# CONFIG_PATH=/path/to/custom-config.yaml
